# ============================================================
# Telegram Bot Configuration
# ============================================================

# Bot token from @BotFather (required)
TELEGRAM_BOT_TOKEN=

# Channel ID where summaries will be posted (required)
# Use numeric ID (e.g., -1001234567890)
# The bot must be an admin in this channel with posting permissions
TELEGRAM_CHANNEL_ID=

# Your Telegram user ID (required)
# Only this user can interact with the bot in DM
# You can get your ID from @userinfobot
TELEGRAM_ADMIN_ID=

# ============================================================
# LLM Provider Configuration
# ============================================================

# OpenRouter API key — used as fallback provider (required)
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Custom LLM provider (optional — overrides OpenRouter if all three are set)
# Must be OpenAI-compatible API
CUSTOM_LLM_API_URL=
CUSTOM_LLM_API_KEY=
CUSTOM_LLM_MODEL=

# ============================================================
# Processing Settings
# ============================================================

# Delay between LLM requests in seconds (default: 2)
LLM_REQUEST_DELAY=2

# Maximum retry attempts for failed articles (default: 3)
LLM_MAX_RETRIES=3

# ============================================================
# Database
# ============================================================

# Path to SQLite database file (default: data/bot.db)
# DB_PATH=data/bot.db

# ============================================================
# Aggregator (Content Pipeline)
# ============================================================

# Enable the aggregator subsystem (default: false)
AGGREGATOR_ENABLED=false

# Comma-separated list of enabled source connectors
# Available: rss_example (add your own in src/aggregator/sources/)
AGGREGATOR_ENABLED_SOURCES=

# Schedule: number (minutes between runs) or "cron:M H D MON DOW"
# Examples: "60" = every hour, "cron:0 9 * * *" = daily at 9:00
AGGREGATOR_SCHEDULE=60

# Tone preset name (matches prompts/digest_{tone}.j2)
# Default: "default" → neutral technical reviewer tone
AGGREGATOR_TONE=default

# ── Source-specific settings ──────────────────────────────

# RSS source: comma-separated feed URLs
# RSS_FEED_URLS=https://example.com/feed.xml,https://other.com/rss
